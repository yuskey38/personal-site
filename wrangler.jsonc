{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "personal-site",
	"compatibility_date": "2026-06-16",
	"observability": {
		"enabled": true
	},
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"compatibility_flags": [
		"nodejs_compat"
	]
}
